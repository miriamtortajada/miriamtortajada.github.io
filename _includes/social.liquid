<div class="contact-icons">
  {% if site.data.socials.email %}
    <a href="mailto:{{ site.data.socials.email | encode_email }}" title="email"><i class="fa-solid fa-envelope"></i></a>
  {% endif %}
  {% if site.data.socials.cv_pdf %}
    <a href="{{ site.data.socials.cv_pdf | relative_url }}" title="CV" target="_blank"><i class="ai ai-cv"></i></a>
  {% endif %}
  {% if site.data.socials.orcid_id %}
    <a href="https://orcid.org/{{ site.data.socials.orcid_id }}" title="ORCID" target="_blank" rel="noopener noreferrer"><i class="ai ai-orcid"></i></a>
  {% endif %}
  {% if site.data.socials.scholar_userid %}
    <a href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" title="Google Scholar" target="_blank" rel="noopener noreferrer"><i class="ai ai-google-scholar"></i></a>
  {% endif %}
  {% if site.data.socials.inspirehep_id %}
    <a href="https://inspirehep.net/authors/{{ site.data.socials.inspirehep_id }}" title="Inspire HEP" target="_blank" rel="noopener noreferrer"><i class="ai ai-inspire"></i></a>
  {% endif %}
  {% if site.data.socials.semanticscholar_id %}
    <a href="https://www.semanticscholar.org/author/{{ site.data.socials.semanticscholar_id }}" title="Semantic Scholar" target="_blank" rel="noopener noreferrer"><i class="ai ai-semantic-scholar"></i></a>
  {% endif %}
  {% if site.data.socials.publons_id %}
    <a href="https://publons.com/a/{{ site.data.socials.publons_id }}/" title="Publons" target="_blank" rel="noopener noreferrer"><i class="ai ai-publons"></i></a>
  {% endif %}
  {% if site.data.socials.lattes_id %}
    <a href="http://lattes.cnpq.br/{{ site.data.socials.lattes_id }}" title="Lattes" target="_blank" rel="noopener noreferrer"><i class="ai ai-lattes"></i></a>
  {% endif %}
  {% if site.data.socials.osf_id %}
    <a href="https://osf.io/{{ site.data.socials.osf_id }}/" title="Open Science Framework" target="_blank" rel="noopener noreferrer"><i class="ai ai-osf"></i></a>
  {% endif %}
  {% if site.data.socials.research_gate_profile %}
    <a href="https://www.researchgate.net/profile/{{ site.data.socials.research_gate_profile }}/" title="ResearchGate" target="_blank" rel="noopener noreferrer"><i class="ai ai-researchgate"></i></a>
  {% endif %}
  {% if site.data.socials.ieee_id %}
    <a href="https://ieeexplore.ieee.org/author/{{ site.data.socials.ieee_id }}/" title="IEEE Xplore" target="_blank" rel="noopener noreferrer"><i class="ai ai-ieee"></i></a>
  {% endif %}
  {% if site.data.socials.acm_id %}
    <a href="https://dl.acm.org/profile/{{ site.data.socials.acm_id }}/" title="ACM DL" target="_blank" rel="noopener noreferrer"><i class="ai ai-acm"></i></a>
  {% endif %}
  {% if site.data.socials.scopus_id %}
    <a href="https://www.scopus.com/authid/detail.uri?authorId={{ site.data.socials.scopus_id }}" title="Scopus" target="_blank" rel="noopener noreferrer"><i class="ai ai-scopus"></i></a>
  {% endif %}
  {% if site.data.socials.github_username %}
    <a href="https://github.com/{{ site.data.socials.github_username }}" title="GitHub" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-github"></i></a>
  {% endif %}
  {% if site.data.socials.linkedin_username %}
    <a href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}" title="LinkedIn" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-linkedin"></i></a>
  {% endif %}
  {% if site.data.socials.x_username %}
    <a href="https://twitter.com/{{ site.data.socials.x_username }}" title="X" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-x-twitter"></i></a>
  {% endif %}
  {% if site.data.socials.mastodon_username %}
    <a rel="me" href="https://{{ site.data.socials.mastodon_username }}" title="Mastodon" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-mastodon"></i></a>
  {% endif %}
  {% if site.data.socials.bluesky_url %}
    <a href="{{ site.data.socials.bluesky_url }}" title="Bluesky" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-bluesky"></i></a>
  {% endif %}
  {% if site.data.socials.medium_username %}
    <a href="https://medium.com/@{{ site.data.socials.medium_username }}" title="Medium" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-medium"></i></a>
  {% endif %}
  {% if site.data.socials.quora_username %}
    <a href="https://www.quora.com/profile/{{ site.data.socials.quora_username }}" title="Quora" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-quora"></i></a>
  {% endif %}
  {% if site.data.socials.blogger_url %}
    <a href="{{ site.data.socials.blogger_url }}" title="Blogger" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-blogger-b"></i></a>
  {% endif %}
  {% if site.data.socials.work_url %}
    <a href="{{ site.data.socials.work_url }}" title="Work" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-briefcase"></i></a>
  {% endif %}
  {% if site.data.socials.kaggle_id %}
    <a href="https://www.kaggle.com/{{ site.data.socials.kaggle_id }}" title="Kaggle" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-kaggle"></i></a>
  {% endif %}
  {% if site.data.socials.telegram_username %}
    <a href="https://telegram.me/{{ site.data.socials.telegram_username }}" title="Telegram" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-telegram"></i></a>
  {% endif %}
  {% if site.data.socials.flickr_id %}
    <a href="https://www.flickr.com/{{ site.data.socials.flickr_id }}" title="Flickr" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-flickr"></i></a>
  {% endif %}
  {% if site.data.socials.whatsapp_number %}
    <a href="https://wa.me/{{ site.data.socials.whatsapp_number }}" title="WhatsApp" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-whatsapp"></i></a>
  {% endif %}
  {% if site.data.socials.wikidata_id %}
    <a href="https://www.wikidata.org/wiki/{{ site.data.socials.wikidata_id }}" title="Wikidata" target="_blank" rel="noopener noreferrer"><i class="fa-solid fa-barcode"></i></a>
  {% endif %}
  {% if site.data.socials.wikipedia_id %}
    <a href="https://wikipedia.org/wiki/User:{{ site.data.socials.wikipedia_id }}" title="Wikipedia" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-wikipedia-w"></i></a>
  {% endif %}
  {% if site.data.socials.strava_userid %}
    <a href="https://www.strava.com/athletes/{{ site.data.socials.strava_userid }}" title="Strava" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-strava"></i></a>
  {% endif %}
  {% if site.data.socials.keybase_username %}
    <a href="https://keybase.io/{{ site.data.socials.keybase_username }}" title="Keybase" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-keybase"></i></a>
  {% endif %}
  {% if site.data.socials.gitlab_username %}
    <a href="https://gitlab.com/{{ site.data.socials.gitlab_username }}" title="GitLab" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-gitlab"></i></a>
  {% endif %}
  {% if site.data.socials.dblp_url %}
    <a href="{{ site.data.socials.dblp_url }}" title="DBLP" target="_blank" rel="noopener noreferrer"><i class="ai ai-dblp"></i></a>
  {% endif %}
  {% if site.data.socials.stackoverflow_id %}
    <a href="https://stackoverflow.com/users/{{ site.data.socials.stackoverflow_id }}" title="Stackoverflow" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-stack-overflow"></i></a>
  {% endif %}
  {% if site.data.socials.lastfm_id %}
    <a href="https://www.last.fm/user/{{ site.data.socials.lastfm_id }}" title="Last FM" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-lastfm"></i></a>
  {% endif %}
  {% if site.data.socials.spotify_id %}
    <a href="https://open.spotify.com/user/{{ site.data.socials.spotify_id }}" title="Spotify" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-spotify"></i></a>
  {% endif %}
  {% if site.data.socials.pinterest_id %}
    <a href="https://www.pinterest.com/{{ site.data.socials.pinterest_id }}" title="Pinterest" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-pinterest"></i></a>
  {% endif %}
  {% if site.data.socials.unsplash_id %}
    <a href="https://unsplash.com/@{{ site.data.socials.unsplash_id }}" title="Unsplash" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-unsplash"></i></a>
  {% endif %}
  {% if site.data.socials.instagram_id %}
    <a href="https://instagram.com/{{ site.data.socials.instagram_id }}" title="Instagram" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-instagram"></i></a>
  {% endif %}
  {% if site.data.socials.facebook_id %}
    <a href="https://facebook.com/{{ site.data.socials.facebook_id }}" title="Facebook" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-facebook"></i></a>
  {% endif %}
  {% if site.data.socials.youtube_id %}
    <a href="https://youtube.com/@{{ site.data.socials.youtube_id }}" title="YouTube" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-youtube"></i></a>
  {% endif %}
  {% if site.data.socials.discord_id %}
    <a href="https://discord.com/users/{{ site.data.socials.discord_id }}" title="Discord" target="_blank" rel="noopener noreferrer"><i class="fa-brands fa-discord"></i></a>
  {% endif %}
  {% if site.data.socials.zotero_username %}
    <a href="https://www.zotero.org/{{ site.data.socials.zotero_username }}" title="Zotero" target="_blank" rel="noopener noreferrer"><i class="ai ai-zotero"></i></a>
  {% endif %}
  {% if site.data.socials.rss_icon %}
    <a href="{{ site.baseurl }}/feed.xml" title="RSS Feed"><i class="fa-solid fa-square-rss"></i></a>
  {% endif %}
  {% if site.data.socials.wechat_qr %}
    <a id="WeChatBtn" title="WeChat"><i class="fa-brands fa-weixin"></i></a>
    <div id="WeChatMod" class="wechat-modal">
      <img src="{{ site.data.socials.wechat_qr | prepend: 'assets/img/' | relative_url }}" alt="WeChat QR" id="WeChatQR">
    </div>
    {% include scripts/wechatModal.liquid %}
  {% endif %}
</div>
